def not_if: Bool -> Bool =
    fun(b: Bool) => match b {
        true => false,
        false => true,
    };

def not_if_self_inverse: fun(b: Bool) ->
    Eq(
        @Bool,
        match match b {
            true => false,
            false => true,
        } {
            true => false,
            false => true,
        },
        b
    ) =
    fun(a: Bool) => match a {
        true => refl(@Bool, true),
        false => refl(@Bool, false),
    };

def bool_rec_if: fun(b: Bool, p: Bool -> Type) -> p(true) -> p(false) -> p(b) =
    fun(
        a: Bool,
        p: Bool -> Type,
        p_true: p(true),
        p_false: p(false)
    ) => match a {
        true => p_true,
        false => p_false,
    };

def not_match: Bool -> Bool =
    fun(b: Bool) => match b {
        true => false,
        false => true,
    };

def not_match_self_inverse: fun(b: Bool) ->
    Eq(
        @Bool,
        match match b {
            true => false,
            false => true,
        } {
            true => false,
            false => true,
        },
        b
    ) =
    fun(a: Bool) => match a {
        true => refl(@Bool, true),
        false => refl(@Bool, false),
    };

def bool_rec_match: fun(b: Bool, p: Bool -> Type) -> p(true) ->
    p(false) -> p(b) =
    fun(
        a: Bool,
        p: Bool -> Type,
        p_true: p(true),
        p_false: p(false)
    ) => match a {
        true => p_true,
        false => p_false,
    };

def bool_pair_rec: fun(b: (Bool, Bool), p: Bool -> Bool -> Type) ->
    p(true, true) ->
    p(true, false) -> p(false, true) -> p(false, false) -> p(b._0, b._1) =
    fun(
        a: (Bool, Bool),
        p: Bool -> Bool -> Type,
        p_tt: p(true, true),
        p_tf: p(true, false),
        p_ft: p(false, true),
        p_ff: p(false, false)
    ) => match a._0 {
        true => match a._1 {
            true => p_tt,
            false => p_tf,
        },
        false => match a._1 {
            true => p_ft,
            false => p_ff,
        },
    };

def two_bools_rec: fun(b1: Bool, b2: Bool, p: Bool -> Bool -> Type) ->
    p(true, true) ->
    p(true, false) -> p(false, true) -> p(false, false) -> p(b1, b2) =
    fun(
        a1: Bool,
        a2: Bool,
        p: Bool -> Bool -> Type,
        p_tt: p(true, true),
        p_tf: p(true, false),
        p_ft: p(false, true),
        p_ff: p(false, false)
    ) => match (a1, a2)._0 {
        true => match (a1, a2)._1 {
            true => p_tt,
            false => p_tf,
        },
        false => match (a1, a2)._1 {
            true => p_ft,
            false => p_ff,
        },
    };
