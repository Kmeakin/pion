def not = fun(b: Bool) => if b then false else true;

def not_self_inverse: fun(b: Bool) -> Eq(not(not(b)), b)
    = fun(a: Bool) => if a then refl(_) else refl(_);

def manual_bool_rec: fun(b: Bool, p: Bool -> Type) -> p(true) -> p(false) -> p(b)
    = fun(a: Bool, p, p_true, p_false) => if a then p_true else p_false;
