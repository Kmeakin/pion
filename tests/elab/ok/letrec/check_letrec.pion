def foo =
    let rec x = 0;
        rec y = x;
        y;

def bar =
    let rec fact: Int -> Int = fun(x: Int) => match x {
        0 => 1,
        1 => 1,
        _ => mul(x, fact(sub(x, 1))),
    };
    fact;

